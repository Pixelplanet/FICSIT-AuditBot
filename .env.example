# ---- Save files ----
# Folder containing Satisfactory save files to watch.
SAVES_DIR=./Saves

# Glob/suffix that identifies the canonical (non-autosave) save to track.
# Default tracks files ending in "_continue.sav".
# For dedicated servers, use ".sav" to follow rotating autosaves.
CANONICAL_SAVE_SUFFIX=_continue.sav

# Dedicated-server mode: when > 0, the bot infers the autosave cadence from
# save mtimes and prefers the newest save that is OFF that cadence (typically
# a disconnect/player-triggered save). Set 0 to disable and use newest suffix.
AUTOSAVE_INTERVAL_MINUTES=0

# Allowed timing drift (seconds) when matching the autosave cadence.
AUTOSAVE_TIME_TOLERANCE_SECONDS=2

# ---- Storage ----
# Single data root. When set, state/ and docs/ default to subfolders of it, so
# a container only needs ONE internal volume mounted here (the image sets this
# to /data). Leave blank for local runs to use ./state and auto-discovered docs.
DATA_DIR=

# Path to the game's documentation file used to resolve real names + unlocks.
# Point at the file, its folder, or the game install root. Blank = auto-detect
# (or <DATA_DIR>/docs when DATA_DIR is set).
#   Steam:  .../Satisfactory/CommunityResources/Docs/Docs.json
#   1.0+ :  .../CommunityResources/Docs/en-US.json
DOCS_PATH=

# Directory where snapshots + db.json are stored. Blank = <DATA_DIR>/state when
# DATA_DIR is set, otherwise ./state.
STATE_DIR=

# ---- Behaviour ----
# Post to Discord. If false, the summary is only printed to the console.
POST_TO_DISCORD=false

# Skip posting when the only change is elapsed time (e.g. an idle restart).
SKIP_EMPTY_SUMMARIES=true

# Debounce window (ms) after a save file write before processing it.
WATCH_DEBOUNCE_MS=5000

# Space Elevator parts cost multiplier override. 0 = auto-detect from the save
# (the game stores this as mSpacePartsCostMultiplier). Set a positive number to
# force a factor (e.g. 2 for a 2x custom game), useful if the save lacks it.
PHASE_COST_MULTIPLIER=0

# Use filesystem polling to detect changes (recommended inside Docker / bind mounts).
WATCH_USE_POLLING=false

# ---- Web UI ----
# Enable the configuration + preview web UI.
WEB_ENABLED=true
# Port the web UI listens on.
WEB_PORT=8080

# ---- Dedicated server HTTPS API (optional) ----
# Enables live server-state checks (paused/players/milestone/phase) via
# QueryServerState, used to avoid posting from regular autosaves while players
# are still online.
SERVER_API_URL=
SERVER_API_TOKEN=
SERVER_API_ALLOW_INSECURE_TLS=true
SERVER_API_TIMEOUT_MS=5000

# ---- Discord: Webhook delivery ----
# Leave blank to disable webhook delivery.
DISCORD_WEBHOOK_URL=

# ---- Discord: Bot delivery ----
# Leave both blank to disable bot delivery.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# =============================================================================
# Portainer / production (compose.portainer.yaml)
# =============================================================================
# Volume paths are NOT configured here. The production stack uses two explicit
# bind mounts under /mnt/docker_data (one for /data, one for /saves), so there
# are no host-path env vars to get wrong. If your saves live elsewhere, edit
# the single saves bind line directly in compose.portainer.yaml. Only the
# behaviour + Discord vars above are read in production.
