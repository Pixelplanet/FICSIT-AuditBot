# ---- Save files ----
# Folder containing Satisfactory save files to watch.
SAVES_DIR=./Saves

# Glob/suffix that identifies the canonical (non-autosave) save to track.
# Default tracks files ending in "_continue.sav".
CANONICAL_SAVE_SUFFIX=_continue.sav

# Path to the game's documentation file used to resolve real names + unlocks.
# Point at the file, its folder, or the game install root. Blank = auto-detect.
#   Steam:  .../Satisfactory/CommunityResources/Docs/Docs.json
#   1.0+ :  .../CommunityResources/Docs/en-US.json
DOCS_PATH=

# Directory where snapshots + db.json are stored.
STATE_DIR=./state

# ---- Behaviour ----
# Post to Discord. If false, the summary is only printed to the console.
POST_TO_DISCORD=false

# Skip posting when the only change is elapsed time (e.g. an idle restart).
SKIP_EMPTY_SUMMARIES=true

# Debounce window (ms) after a save file write before processing it.
WATCH_DEBOUNCE_MS=5000

# Space Elevator parts cost multiplier override. 0 = auto-detect from the save
# (the game stores this as mSpacePartsCostMultiplier). Set a positive number to
# force a factor (e.g. 2 for a 2x custom game), useful if the save lacks it.
PHASE_COST_MULTIPLIER=0

# Use filesystem polling to detect changes (recommended inside Docker / bind mounts).
WATCH_USE_POLLING=false

# ---- Web UI ----
# Enable the configuration + preview web UI.
WEB_ENABLED=true
# Port the web UI listens on.
WEB_PORT=8080

# ---- Discord: Webhook delivery ----
# Leave blank to disable webhook delivery.
DISCORD_WEBHOOK_URL=

# ---- Discord: Bot delivery ----
# Leave both blank to disable bot delivery.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
